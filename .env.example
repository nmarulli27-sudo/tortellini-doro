# Copia questo file in `.env.local` e inserisci i valori reali.
# `.env.local` non va committato ed e' letto sia da `next dev` che da `next build`.
#
# IMPORTANTE (deploy Cloudflare): `.env.local` NON viene caricato sul Worker.
# Le stesse variabili vanno impostate anche su Cloudflare:
#   Workers & Pages -> tortellino-doro -> Settings -> Variables and Secrets.
# Le chiavi segrete (service role, password, secret, resend) come "Secret".

# --- Supabase ---------------------------------------------------------------
# URL del progetto (Project Settings -> API).
# In locale puoi usare NEXT_PUBLIC_SUPABASE_URL; sul Worker preferisci
# SUPABASE_URL (variabile runtime, non "congelata" in fase di build).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Service role key: SOLO lato server, mai esposta al browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Area riservata / admin -------------------------------------------------
# Password del login admin (/it/admin/login).
ADMIN_PASSWORD=scegli-una-password-robusta
# Valore del cookie di sessione: stringa casuale lunga (es. `openssl rand -hex 32`).
# Se manca, il login va in loop e rimanda sempre alla pagina di accesso.
ADMIN_SESSION_SECRET=stringa-casuale-lunga

# --- Email di conferma (Resend) ---------------------------------------------
RESEND_API_KEY=your-resend-api-key
RESTAURANT_EMAIL=prenotazioni@iltuoristorante.it

# --- Sito -------------------------------------------------------------------
# NON piu' necessaria: i redirect e i link email usano l'host della richiesta.
# Lasciata solo come riferimento. Se la imposti, dev'essere l'URL REALE del
# sito (un valore sbagliato qui non rompe piu' nulla, ma evita confusione).
# NEXT_PUBLIC_SITE_URL=https://tortellini-doro.n-marulli27.workers.dev
